{
  "name": "reparo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "simulate:live": "npx --yes tsx tests/live-simulation/runner.ts",
    "test:auction": "npx --yes tsx tests/auction-scenarios.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "db:start": "npx --yes supabase start",
    "db:stop": "npx --yes supabase stop",
    "db:reset": "npx --yes supabase db reset",
    "db:status": "npx --yes supabase status"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@hookform/resolvers": "^5.2.2",
    "@playwright/test": "^1.59.1",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.43.4",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.383.0",
    "next": "^14.2.35",
    "papaparse": "^5.5.3",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.75.0",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "stripe": "^22.1.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
