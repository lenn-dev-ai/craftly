# Craftly — Umgebungsvariablen
# Diese Datei in .env.local umbenennen und Werte aus Supabase einfügen

NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key-hier

# Mapbox — für Adress-Autocomplete und Karten
# Token erstellen: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.dein-mapbox-token-hier
