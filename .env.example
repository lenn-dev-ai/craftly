# Reparo — Umgebungsvariablen
# Diese Datei in .env.local umbenennen und Werte aus Supabase einfügen

NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key-hier

# Adress-Autocomplete läuft über Photon (Komoot) — kein Token nötig.
# Falls später eine professionelle Variante (Mapbox, Google) gewünscht ist,
# hier den entsprechenden Token + Anpassung in components/AddressAutocomplete.tsx.

# Auf "true" setzen, sobald echte Impressum-/Datenschutz-Daten eingetragen sind.
# Solange leer/false: gelber Platzhalter-Banner auf den Rechtsseiten.
# NEXT_PUBLIC_REPARO_LIVE_DATA=true

# Plausible Analytics — DSGVO-friendly, cookie-frei.
# Wenn gesetzt, wird das Tracking-Script in den <head> eingefügt.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=reparo-app.netlify.app
# Optional Self-Hosted: NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.eigene-domain.de/js/script.js
