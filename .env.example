# Reparo — Umgebungsvariablen
# Diese Datei in .env.local umbenennen und Werte aus Supabase einfügen

NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key-hier

# Adress-Autocomplete läuft über Photon (Komoot) — kein Token nötig.
# Falls später eine professionelle Variante (Mapbox, Google) gewünscht ist,
# hier den entsprechenden Token + Anpassung in components/AddressAutocomplete.tsx.

# Impressum / Datenschutz — Betreiberdaten
# Solange leer: Platzhalter wie [DEINE-EMAIL] werden angezeigt + Warnbanner auf Rechtsseiten.
# Beim Launch alle vier Felder setzen UND NEXT_PUBLIC_REPARO_LIVE_DATA=true,
# dann verschwindet der Banner.
# NEXT_PUBLIC_REPARO_BETREIBER_NAME=Lennart Mustermann
# NEXT_PUBLIC_REPARO_BETREIBER_STRASSE=Musterstraße 1
# NEXT_PUBLIC_REPARO_BETREIBER_PLZORT=10115 Berlin
# NEXT_PUBLIC_REPARO_KONTAKT_EMAIL=kontakt@reparo-app.de
# NEXT_PUBLIC_REPARO_KONTAKT_TELEFON=+49 30 123456789  # optional
# NEXT_PUBLIC_REPARO_LIVE_DATA=true

# Plausible Analytics — DSGVO-friendly, cookie-frei.
# Wenn gesetzt, wird das Tracking-Script in den <head> eingefügt.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=reparo-app.netlify.app
# Optional Self-Hosted: NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.eigene-domain.de/js/script.js

# Resend — transaktionale E-Mails (Auktion-Events, Welcome, Feedback-Notify).
# Solange RESEND_API_KEY nicht gesetzt ist, sind alle E-Mail-Versendungen
# No-Ops (das System läuft trotzdem, nur ohne Mails).
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=Reparo <noreply@reparo-app.de>

# Empfänger für Beta-Feedback-Notifications (POST /api/feedback).
# Wenn nicht gesetzt: Feedback landet trotzdem in DB / Admin-Inbox,
# nur keine Mail-Benachrichtigung an Reparo.
# REPARO_FEEDBACK_EMAIL=feedback@reparo-app.de

# Site-URL für absolute Links in transaktionalen E-Mails.
# Default Fallback: https://reparo-app.netlify.app
# NEXT_PUBLIC_SITE_URL=https://reparo-app.netlify.app

# Cron-Secret für /api/auction/check-expired (Notify + Auto-Vergabe).
# Setzen wenn ein externer Cron (Netlify Scheduled, GitHub Actions, etc.)
# den Endpoint mit Header x-cron-secret aufruft. Ohne Secret nur Admin-Auth.
# CRON_SECRET=zufaellige-zeichenkette-hier

# Anthropic Claude — KI-Schadenserkennung aus Foto in /dashboard-mieter/melden.
# Ohne API-Key liefert /api/ki/schadenserkennung 503 und das Mieter-UI
# fällt automatisch auf die Regex-Heuristik aus dem Beschreibungstext zurück.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Stripe — Connect-Onboarding für HW + spätere Penalty-Buchung.
# Solange STRIPE_SECRET_KEY nicht gesetzt ist, zeigt die HW-Verdienst-
# Seite eine "noch nicht aktiviert"-Meldung statt eines Buttons; alle
# /api/stripe/*-Endpoints returnen 503. Der Cron markiert Frist-Penalties
# als 'manual_pending' (Reparo verrechnet manuell), unabhängig davon
# ob Stripe konfiguriert ist.
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# STRIPE_PLATFORM_ACCOUNT_ID=acct_xxxxxxxxxxxx  # optional, nur falls explizit
                                                # platform-charge gebraucht
